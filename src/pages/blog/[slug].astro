---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryLabels = {
  activites: 'Activités',
  region: 'Région',
  sejour: 'Séjour',
  conseils: 'Conseils',
};
---

<BaseLayout
  title={`${post.data.title} — Blog Gîte de l'Ormoy`}
  description={post.data.description}
  image={post.data.image}
>
  <!-- Hero -->
  <section class="relative h-[55vh] overflow-hidden">
    {post.data.image ? (
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image: url(${post.data.image})`}
      >
        <div class="hero-overlay"></div>
      </div>
    ) : (
      <div class="absolute inset-0 bg-primary">
        <div class="absolute inset-0 opacity-20" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')"></div>
      </div>
    )}
    <div class="relative z-10 h-full flex items-center justify-center text-center px-6">
      <div class="max-w-3xl">
        {post.data.category && (
          <p class="section-label text-white/70 mb-4">
            {categoryLabels[post.data.category] || post.data.category}
          </p>
        )}
        <h1 class="font-heading text-4xl md:text-6xl font-light text-white leading-tight">
          {post.data.title}
        </h1>
        <p class="font-body text-white/70 text-sm mt-4">
          {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
          {post.data.readingTime && ` · ${post.data.readingTime} min de lecture`}
        </p>
      </div>
    </div>
  </section>

  <!-- Article content -->
  <article class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Back link -->
      <a href="/blog" class="inline-flex items-center gap-2 font-body text-sm text-muted-foreground hover:text-primary transition-colors mb-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Retour au blog
      </a>

      <!-- Prose content -->
      <div class="prose prose-lg max-w-none
        prose-headings:font-heading prose-headings:font-light
        prose-p:font-body prose-p:text-muted-foreground prose-p:leading-relaxed
        prose-a:text-primary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-foreground
        prose-img:rounded-2xl
        prose-blockquote:border-l-primary prose-blockquote:font-heading prose-blockquote:italic">
        <Content />
      </div>

      <!-- Divider -->
      <hr class="my-16 border-border" />

      <!-- CTA at end of article -->
      <div class="text-center">
        <p class="font-heading text-2xl font-light text-foreground mb-4">
          Envie de vivre cette expérience ?
        </p>
        <p class="font-body text-muted-foreground text-sm mb-6">
          Réservez votre séjour au Gîte de l'Ormoy et profitez de tout ce que la Sologne a à offrir.
        </p>
        <a href="/contact" class="btn-primary">Demander une réservation</a>
      </div>
    </div>
  </article>
</BaseLayout>
