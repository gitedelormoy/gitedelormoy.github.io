---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalerieGrid from '../components/GalerieGrid.jsx';
---

<BaseLayout
  title="Galerie — Gîte de l'Ormoy"
  description="Découvrez en images le Gîte de l'Ormoy : chambres, véranda, jardin et espaces extérieurs de ce meublé de tourisme 4 étoiles en Sologne."
>
  <!-- Hero -->
  <section class="relative h-[55vh] overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url(https://res.cloudinary.com/dpgmwola2/image/upload/q_auto/f_auto/v1775496846/Extrtiot_gjxge4.png)"
    >
      <div class="hero-overlay"></div>
    </div>
    <div class="relative z-10 h-full flex items-center justify-center text-center px-6">
      <div>
        <p class="section-label text-white/70 mb-3">Photos</p>
        <h1 class="font-heading text-6xl md:text-8xl font-light text-white">Galerie</h1>
        <p class="font-body text-white/60 text-sm mt-4 tracking-widest uppercase">17 photos</p>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-14 px-6 text-center max-w-2xl mx-auto">
    <p class="font-heading text-xl font-light text-muted-foreground italic">
      Chaque espace a été pensé pour allier authenticité et confort moderne.
    </p>
  </section>

  <!-- Gallery -->
  <section class="pb-20 px-4 md:px-8 lg:px-12">
    <GalerieGrid client:load />
  </section>

  <!-- CTA -->
  <section class="py-16 px-6 bg-primary text-primary-foreground text-center">
    <h2 class="font-heading text-3xl md:text-4xl font-light mb-4">Envie de vivre cette expérience ?</h2>
    <p class="font-body text-primary-foreground/75 mb-8 text-sm max-w-md mx-auto">
      Réservez votre séjour et profitez de ce cadre d'exception en Sologne.
    </p>
    <a href="/reserver" class="inline-block px-8 py-3.5 bg-primary-foreground text-primary rounded-full font-body font-medium text-sm hover:bg-primary-foreground/90 transition-all duration-300">
      Demander une réservation
    </a>
  </section>
</BaseLayout>
